# Salin file ini menjadi .env lalu isi nilainya:
#   cp .env.example .env

# Aktifkan integrasi Google Spreadsheet (true/false)
USE_SPREADSHEET=true

# Nama file kunci service-account (letakkan file-nya di root repo, jangan di-commit)
KEY_FILE_NAME=credentials.json

# ID spreadsheet tujuan, ambil dari URL:
# https://docs.google.com/spreadsheets/d/<ID_DI_SINI>/edit
SHEET_ID=your_spreadsheet_id_here
